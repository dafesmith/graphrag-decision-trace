# Copy to .env on the VPS (do NOT commit). Used by docker-compose.prod.yml.

NEO4J_PASSWORD=change-me-strong-password

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Comma-separated list of allowed CORS origins for the FastAPI backend.
# Include your Vercel production domain and any preview pattern you use.
CORS_ALLOW_ORIGINS=https://your-frontend.vercel.app,https://*.vercel.app
